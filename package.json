  "main": "index.js",
  "scripts": {
    "dev": "tsx watch index.js",
    "start": "node index.js",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "DATABASE_URL=postgres://testuser:testpass@localhost:5433/docugen_test vitest run",
